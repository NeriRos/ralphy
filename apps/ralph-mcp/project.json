{
  "name": "ralph-mcp",
  "sourceRoot": "apps/ralph-mcp/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun build apps/ralph-mcp/src/index.ts --outdir apps/ralph-mcp/dist --target bun"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p apps/ralph-mcp/tsconfig.json"
      }
    }
  }
}
