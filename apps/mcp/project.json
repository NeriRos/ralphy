{
  "name": "mcp",
  "sourceRoot": "apps/mcp/src",
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxlint --config .oxlintrc.json apps/mcp/src",
        "cwd": "{workspaceRoot}"
      }
    },
    "fmt:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxfmt --check apps/mcp/src",
        "cwd": "{workspaceRoot}"
      }
    },
    "check:circular": {
      "executor": "nx:run-commands",
      "options": {
        "command": "madge --circular --extensions ts apps/mcp/src",
        "cwd": "{workspaceRoot}"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun build apps/mcp/src/index.ts --outdir dist/mcp --target bun"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p apps/mcp/tsconfig.json"
      }
    }
  }
}
