{
  "name": "mcp",
  "sourceRoot": "apps/mcp/src",
  "tags": ["scope:mcp"],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxlint --config .oxlintrc.json apps/mcp/src",
        "cwd": "{workspaceRoot}"
      }
    },
    "fmt:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxfmt --check apps/mcp/src",
        "cwd": "{workspaceRoot}"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun build apps/mcp/src/index.ts --outdir dist/mcp --target bun"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun test apps/mcp/src",
        "cwd": "{workspaceRoot}"
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun test --coverage src",
        "cwd": "{projectRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -b apps/mcp/tsconfig.json"
      }
    }
  }
}
