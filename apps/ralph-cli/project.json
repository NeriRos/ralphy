{
  "name": "ralph-cli",
  "sourceRoot": "apps/ralph-cli/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun build apps/ralph-cli/src/index.ts --outdir apps/ralph-cli/dist --target bun",
        "cwd": "{workspaceRoot}"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p apps/ralph-cli/tsconfig.json",
        "cwd": "{workspaceRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun test apps/ralph-cli/src",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
