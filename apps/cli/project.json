{
  "name": "cli",
  "sourceRoot": "apps/cli/src",
  "tags": ["scope:cli"],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxlint --config .oxlintrc.json apps/cli/src",
        "cwd": "{workspaceRoot}"
      }
    },
    "fmt:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxfmt --check apps/cli/src",
        "cwd": "{workspaceRoot}"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun build apps/cli/src/index.ts --outdir dist/cli --target bun",
        "cwd": "{workspaceRoot}"
      },
      "outputs": ["{workspaceRoot}/dist/cli"]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -b apps/cli/tsconfig.json",
        "cwd": "{workspaceRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun test apps/cli/src",
        "cwd": "{workspaceRoot}"
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun test --coverage src",
        "cwd": "{projectRoot}"
      }
    }
  }
}
