{
  "name": "change-store",
  "sourceRoot": "packages/change-store/src",
  "tags": ["scope:shared"],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxlint --config .oxlintrc.json packages/change-store/src",
        "cwd": "{workspaceRoot}"
      }
    },
    "fmt:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxfmt --check packages/change-store/src",
        "cwd": "{workspaceRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -b packages/change-store/tsconfig.json",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
