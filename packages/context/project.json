{
  "name": "context",
  "sourceRoot": "packages/context/src",
  "tags": ["scope:shared"],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxlint --config .oxlintrc.json packages/context/src",
        "cwd": "{workspaceRoot}"
      }
    },
    "fmt:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxfmt --check packages/context/src",
        "cwd": "{workspaceRoot}"
      }
    },
    "check:circular": {
      "executor": "nx:run-commands",
      "options": {
        "command": "madge --circular --extensions ts packages/context/src",
        "cwd": "{workspaceRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -b packages/context/tsconfig.json",
        "cwd": "{workspaceRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun test packages/context/src",
        "cwd": "{workspaceRoot}"
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun test --coverage packages/context/src",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
