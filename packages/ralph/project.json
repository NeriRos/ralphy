{
  "name": "ralph",
  "sourceRoot": "packages/ralph/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun build packages/ralph/src/index.ts --outdir packages/ralph/dist --target bun",
        "cwd": "{workspaceRoot}"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p packages/ralph/tsconfig.json",
        "cwd": "{workspaceRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun test packages/ralph/src",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
