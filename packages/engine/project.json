{
  "name": "engine",
  "sourceRoot": "packages/engine/src",
  "tags": ["scope:cli"],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxlint --config .oxlintrc.json packages/engine/src",
        "cwd": "{workspaceRoot}"
      }
    },
    "fmt:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxfmt --check packages/engine/src",
        "cwd": "{workspaceRoot}"
      }
    },
    "check:circular": {
      "executor": "nx:run-commands",
      "options": {
        "command": "madge --circular --extensions ts packages/engine/src",
        "cwd": "{workspaceRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -b packages/engine/tsconfig.json",
        "cwd": "{workspaceRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun test packages/engine/src",
        "cwd": "{workspaceRoot}"
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun test --coverage src",
        "cwd": "{projectRoot}"
      }
    }
  }
}
