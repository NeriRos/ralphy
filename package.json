{
  "name": "ralphy",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "tools/generators/*"
  ],
  "type": "module",
  "scripts": {
    "ralph": "bun .ralph/bin/cli.js",
    "lint": "oxlint --config .oxlintrc.json .",
    "lint:fix": "oxlint --config .oxlintrc.json --fix .",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "typecheck": "nx affected -t typecheck",
    "check:circular": "madge --circular --extensions ts packages/*/src apps/*/src",
    "check:deps": "depcruise packages/*/src apps/*/src --config .dependency-cruiser.cjs",
    "check:unused": "knip",
    "lint:ci": "nx affected -t lint",
    "fmt:ci": "nx affected -t fmt:check",
    "typecheck:ci": "nx affected -t typecheck",
    "test:ci": "nx affected -t test",
    "check:circular:ci": "nx affected -t check:circular",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "chalk": "^5.4.0",
    "front-matter": "^4.0.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@nx/devkit": "^22.5.3",
    "@nx/js": "^22.5.3",
    "@secretlint/secretlint-rule-preset-recommend": "^11.3.1",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.18",
    "@types/node": "^22.0.0",
    "bun-types": "^1.3.0",
    "dependency-cruiser": "^17.3.8",
    "husky": "^9.1.7",
    "knip": "^5.85.0",
    "lint-staged": "^16.3.2",
    "madge": "^8.0.0",
    "nx": "22.5.3",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "secretlint": "^11.3.1",
    "typescript": "^5.8.0"
  }
}
