{
  "$schema": "https://json-schema.org/schema",
  "id": "lib",
  "title": "Create a library",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Library name (e.g., utils)",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "What name would you like to use for the library?"
    }
  },
  "required": ["name"]
}
