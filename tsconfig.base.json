{
  "compilerOptions": {
    // --- Module & Emit ---

    // Use latest JS features; Bun supports them natively so no down-leveling needed
    "target": "ESNext",
    // ESM output to match Bun's native module system
    "module": "ESNext",
    // "bundler" resolution understands package.json "exports" and doesn't require file extensions,
    // matching how Bun actually resolves modules
    "moduleResolution": "bundler",
    // Allow default-importing CommonJS modules (e.g. `import chalk from "chalk"`)
    "esModuleInterop": true,
    // Require `import type` for type-only imports; ensures bundlers can safely tree-shake
    "verbatimModuleSyntax": true,
    // Treat each file as an independent transpilation unit (required by bundlers and SWC)
    "isolatedModules": true,
    // Allow `import config from "./config.json"`
    "resolveJsonModule": true,
    // Treat every file as a module even without imports/exports; prevents accidental global scripts
    "moduleDetection": "force",
    // Only allow type syntax that can be erased (bans enum, parameter properties, namespace);
    // aligns with TC39 type annotations proposal and prevents enum-related bugs
    "erasableSyntaxOnly": true,

    // --- Type Checking (strict + extras) ---

    // Enable all strict type-checking flags (strictNullChecks, noImplicitAny, etc.)
    "strict": true,
    // Force `obj[key]` to return `T | undefined`, catching missing-key bugs at compile time
    "noUncheckedIndexedAccess": true,
    // Distinguish between `{ x?: number }` (may be missing) and `{ x: number | undefined }` (present but undefined)
    "exactOptionalPropertyTypes": true,
    // Require the `override` keyword when overriding base-class methods, preventing silent breakage
    "noImplicitOverride": true,
    // Force bracket notation for index-signature properties (e.g. `obj["key"]` not `obj.key`),
    // making it explicit when a property is known vs dynamic
    "noPropertyAccessFromIndexSignature": true,
    // Stricter return type for built-in iterators (not included in `strict`); prevents iterator returns from being `any`
    "strictBuiltinIteratorReturn": true,
    // Validate that side-effect imports (e.g. `import "./setup"`) actually resolve to a file
    "noUncheckedSideEffectImports": true,

    // --- AI & Diagnostics ---

    // Show full type errors without truncation; critical for AI agents that parse compiler output
    "noErrorTruncation": true,

    // --- Build & Output ---

    // Emit .d.ts files so downstream packages get type information
    "declaration": true,
    // Emit .d.ts.map files so "Go to Definition" jumps to the source .ts, not the .d.ts
    "declarationMap": true,
    // Emit .js.map files for debugger support
    "sourceMap": true,
    // Enable project references and incremental builds (required by composite projects)
    "composite": true,

    // --- Environment ---

    // Only expose ESNext APIs; prevents accidentally using DOM globals (document, window) in server code
    "lib": ["ESNext"],
    // Use Bun's type definitions instead of Node's
    "types": ["bun-types"],
    // Skip type-checking third-party .d.ts files for faster builds
    "skipLibCheck": true,
    // Prevent import casing mismatches that break on case-sensitive file systems (Linux CI)
    "forceConsistentCasingInFileNames": true
  },
  "exclude": ["node_modules", "dist"]
}
